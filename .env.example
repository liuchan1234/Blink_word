# Blink.World — Environment Variables
# Copy to .env and fill in actual values

# ── Telegram ──
BOT_TOKEN=
BOT_USERNAME=BlinkWorldBot
WEBHOOK_HOST=
WEBHOOK_SECRET=

# ── Database ──
DATABASE_URL=postgresql://user:pass@localhost:5432/blinkworld
DB_POOL_MIN=5
DB_POOL_MAX=50

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── AI (OpenRouter) ──
AI_API_KEY=
AI_API_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-4o
AI_FALLBACK_MODEL=openai/gpt-4o-mini
AI_DAILY_LIMIT=10000
AI_CONCURRENCY=10

# ── Admin ──
ADMIN_SECRET=
ADMIN_USER_IDS=

# ── Image Generation ──
IMAGE_GEN_PROVIDER=openai
OPENAI_API_KEY=
STABILITY_API_KEY=
IMAGE_GEN_ENABLED=true

# ── App ──
APP_ENV=development
LOG_LEVEL=INFO
